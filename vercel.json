{
  "buildCommand": "CI=false yarn build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "installCommand": "yarn install --ignore-engines",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://siapkandabackend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}